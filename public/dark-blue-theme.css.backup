/* DARK BLUE THEME - Replace Purple with Dark Blue */
:root {
    --dark-blue-primary: #1e40af;    /* Dark Blue (was purple) */
    --blue-secondary: #2563eb;      /* Blue (unchanged) */
    --light-blue: #3b82f6;          /* Light Blue */
    --indigo: #6366f1;              /* Indigo */
    --text-light: #f8fafc;         /* Light text for readability */
    --text-medium: #e2e8f0;        /* Medium text */
    --text-dark: #1e293b;           /* Dark text for contrast */
}

/* Override ALL purple/violet colors with dark blue */
[class*="violet-"],
[class*="purple-"],
.bg-primary,
.text-primary,
.border-primary {
    background-color: #1e40af !important;
    color: #1e40af !important;
    border-color: #1e40af !important;
}

/* Update gradients to use dark blue instead of purple */
.from-violet-600 { --tw-gradient-from: #1e40af !important; }
.from-violet-500 { --tw-gradient-from: #3b82f6 !important; }
.from-violet-400 { --tw-gradient-from: #6366f1 !important; }

.via-blue-500 { --tw-gradient-stops: #1e40af, #2563eb, #3b82f6 !important; }
.via-blue-400 { --tw-gradient-stops: #3b82f6, #60a5fa, #818cf8 !important; }

.to-cyan-400 { --tw-gradient-to: #2563eb !important; }
.to-cyan-300 { --tw-gradient-to: #3b82f6 !important; }
.to-cyan-200 { --tw-gradient-to: #6366f1 !important; }

/* Background color overrides with dark blue theme */
.bg-violet-600\/25 { background-color: rgba(30, 64, 175, 0.25) !important; }
.bg-blue-600\/20 { background-color: rgba(37, 99, 235, 0.20) !important; }
.bg-cyan-500\/25 { background-color: rgba(59, 130, 246, 0.25) !important; }

.bg-violet-500\/20 { background-color: rgba(59, 130, 246, 0.20) !important; }
.bg-blue-500\/15 { background-color: rgba(96, 165, 250, 0.15) !important; }
.bg-cyan-400\/20 { background-color: rgba(129, 140, 248, 0.20) !important; }

/* Text color overrides with better readability */
.text-violet-600 { color: #1e40af !important; }
.text-blue-500 { color: #2563eb !important; }
.text-cyan-400 { color: #3b82f6 !important; }

.text-violet-500 { color: #3b82f6 !important; }
.text-blue-400 { color: #60a5fa !important; }
.text-cyan-300 { color: #6366f1 !important; }

/* Good font colors for readability */
.text-white, .text-gray-50, .text-gray-100 {
    color: #f8fafc !important; /* Light text for dark backgrounds */
}

.text-gray-900, .text-slate-900, .text-foreground {
    color: #1e293b !important; /* Dark text for light backgrounds */
}

.text-gray-600, .text-gray-700, .text-muted {
    color: #64748b !important; /* Medium gray for muted text */
}

/* Button updates with dark blue theme */
.btn-gradient {
    background: linear-gradient(135deg, #1e40af 0%, #2563eb 35%, #3b82f6 70%, #6366f1 100%) !important;
    color: #f8fafc !important; /* Light text for readability */
}

.btn-gradient:hover {
    background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 35%, #60a5fa 70%, #818cf8 100%) !important;
    color: #f8fafc !important;
}

/* Body and section backgrounds with dark blue theme */
body {
    background: linear-gradient(135deg, #1e40af 0%, #2563eb 50%, #3b82f6 100%) !important;
    color: #f8fafc !important; /* Light text for readability */
}

section {
    background: linear-gradient(135deg, rgba(30, 64, 175, 0.1) 0%, rgba(37, 99, 235, 0.1) 50%, rgba(59, 130, 246, 0.1) 100%) !important;
}

/* Card backgrounds with good contrast */
.card, .feature-card, .scroll-reveal {
    background: linear-gradient(135deg, rgba(30, 64, 175, 0.1) 0%, rgba(37, 99, 235, 0.05) 100%) !important;
    border: 1px solid #1e40af !important;
    color: #f8fafc !important; /* Light text for readability */
}

/* Dark mode adjustments */
.dark body {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%) !important;
    color: #f8fafc !important;
}

.dark section {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(96, 165, 250, 0.15) 50%, rgba(129, 140, 248, 0.15) 100%) !important;
}

.dark .card, .dark .feature-card, .dark .scroll-reveal {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(96, 165, 250, 0.05) 100%) !important;
    border: 1px solid #3b82f6 !important;
    color: #f8fafc !important;
}

/* Radial gradient updates */
.bg-\[radial-gradient\(circle_at_top_right\,_rgba\(139\,92\,246\,0\.2\)\,_transparent_50\%\)\] {
    background-image: radial-gradient(circle at top right, rgba(30, 64, 175, 0.3), transparent 50%) !important;
}

.bg-\[radial-gradient\(circle_at_bottom_left\,_rgba\(59\,130\,246\,0\.2\)\,_transparent_50\%\)\] {
    background-image: radial-gradient(circle at bottom left, rgba(37, 99, 235, 0.3), transparent 50%) !important;
}

.dark .bg-\[radial-gradient\(circle_at_top_right\,_rgba\(139\,92\,246\,0\.2\)\,_transparent_50\%\)\] {
    background-image: radial-gradient(circle at top right, rgba(59, 130, 246, 0.4), transparent 50%) !important;
}

.dark .bg-\[radial-gradient\(circle_at_bottom_left\,_rgba\(59\,130\,246\,0\.2\)\,_transparent_50\%\)\] {
    background-image: radial-gradient(circle at bottom left, rgba(96, 165, 250, 0.4), transparent 50%) !important;
}

/* Override all remaining purple/violet with dark blue */
* {
    --color-primary: #1e40af !important;
}

/* Ensure good contrast for all text */
h1, h2, h3, h4, h5, h6 {
    color: #f8fafc !important; /* Light headings for readability */
}

p, span, div {
    color: #e2e8f0 !important; /* Medium-light text for readability */
}

/* Links and interactive elements */
a {
    color: #60a5fa !important; /* Light blue for links */
}

a:hover {
    color: #93c5fd !important; /* Lighter blue on hover */
}
